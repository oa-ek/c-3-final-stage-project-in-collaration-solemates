@page
@model RegisterModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="container my-5 py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4 border-0">
                    <h2 class="h4 fw-bold mb-0 text-uppercase letter-spacing-2">StepStyle</h2>
                    <p class="small opacity-75 mb-0">Приєднуйтесь до нашої спільноти</p>
                </div>

                <div class="card-body p-5">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control border-0 border-bottom rounded-0 shadow-none bg-light" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Електронна пошта</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control border-0 border-bottom rounded-0 shadow-none bg-light" autocomplete="new-password" aria-required="true" placeholder="пароль" />
                            <label asp-for="Input.Password">Пароль</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.ConfirmPassword" class="form-control border-0 border-bottom rounded-0 shadow-none bg-light" autocomplete="new-password" aria-required="true" placeholder="підтвердження пароля" />
                            <label asp-for="Input.ConfirmPassword">Підтвердьте пароль</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button id="registerSubmit" type="submit" class="btn btn-dark btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm mb-3">ЗАРЕЄСТРУВАТИСЯ</button>

                        <div class="text-center mt-4">
                            <p class="small text-muted mb-1">Вже є акаунт?</p>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-dark fw-bold text-decoration-none border-bottom border-dark">Увійти</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .letter-spacing-2 {
        letter-spacing: 2px;
    }

    .form-control:focus {
        background-color: #fcfcfc !important;
        border-color: #000 !important;
    }
</style>