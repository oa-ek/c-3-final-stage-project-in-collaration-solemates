@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="container my-5 py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4 border-0">
                    <h2 class="h4 fw-bold mb-0 text-uppercase letter-spacing-2">StepStyle</h2>
                    <p class="small opacity-75 mb-0">Відновлення доступу до акаунту</p>
                </div>

                <div class="card-body p-5">
                    <p class="text-muted text-center mb-4 small">
                        Забули пароль? Введіть свою пошту, і ми надішлемо вам інструкції для скидання.
                    </p>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control border-0 border-bottom rounded-0 shadow-none bg-light" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Електронна пошта</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark btn-lg w-100 py-3 rounded-pill fw-bold shadow-sm mb-4">
                            СКИНУТИ ПАРОЛЬ
                        </button>

                        <div class="text-center">
                            <a asp-page="./Login" class="text-dark small text-decoration-none border-bottom border-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Повернутися до входу
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .letter-spacing-2 {
        letter-spacing: 2px;
    }

    .form-control:focus {
        background-color: #fcfcfc !important;
        border-color: #000 !important;
        box-shadow: none !important;
    }

    .form-floating > label {
        opacity: 0.7;
    }
</style>