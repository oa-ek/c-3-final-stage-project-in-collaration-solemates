@model StepStyle.Web.Models.Brand

@{
    ViewData["Title"] = "Редагувати бренд";
}

<header class="bg-dark py-4 mb-5 shadow-sm">
    <div class="container px-4 px-lg-5 my-2 text-center text-white text-uppercase">
        <h1 class="display-6 fw-bolder m-0">Редагування: @Model.Name</h1>
    </div>
</header>

<div class="container px-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 p-4 p-md-5 rounded-4">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4 text-center">
                        <label class="form-label fw-bold text-muted small text-uppercase d-block mb-3">Логотип бренду</label>
                        <div class="input-group">
                            <input type="file" name="logoFile" class="form-control border-0 bg-light shadow-none rounded-pill" accept="image/*" id="logoUpload" />
                        </div>
                        <div class="form-text mt-2 small">Оберіть квадратне зображення для кращого вигляду.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold text-muted small text-uppercase">Назва бренду</label>
                        <input asp-for="Name" class="form-control form-control-lg border-0 bg-light shadow-none rounded-pill" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Country" class="form-label fw-bold text-muted small text-uppercase">Країна (англійською для прапора)</label>
                        <div class="input-group">
                            <span class="input-group-text border-0 bg-light rounded-start-pill ps-3">
                                <i class="bi bi-globe-americas"></i>
                            </span>
                            <input asp-for="Country" class="form-control form-control-lg border-0 bg-light shadow-none rounded-end-pill" placeholder="напр. USA, Ukraine, Italy..." />
                        </div>
                        <div class="form-text mt-1 ms-3 small text-muted">Введіть назву країни англійською, щоб підтягнувся прапор.</div>
                        <span asp-validation-for="Country" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 pt-3">
                        <button type="submit" class="btn btn-dark btn-lg flex-grow-1 rounded-pill fw-bold">
                            Оновити дані
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}