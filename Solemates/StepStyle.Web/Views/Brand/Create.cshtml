@model StepStyle.Web.Models.Brand

@{
    ViewData["Title"] = "Додати новий бренд";
}

<header class="bg-dark py-4 mb-5 shadow-sm">
    <div class="container px-4 px-lg-5 my-2 text-center text-white text-uppercase">
        <h1 class="display-6 fw-bolder m-0">Новий партнер</h1>
    </div>
</header>

<div class="container px-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 p-4 p-md-5 rounded-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label text-muted small fw-bold text-uppercase">Назва бренду</label>
                        <input asp-for="Name" class="form-control form-control-lg border-0 bg-light shadow-none" placeholder="Наприклад: Puma, Nike..." required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Country" class="form-label text-muted small fw-bold text-uppercase">Країна походження</label>
                        <input asp-for="Country" class="form-control form-control-lg border-0 bg-light shadow-none" placeholder="Наприклад: Ukraine, USA, Germany..." required />
                        <small class="text-muted" style="font-size: 0.75rem;">Введіть назву країни англійською для коректної роботи API прапорів</small>
                        <span asp-validation-for="Country" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 pt-2">
                        <button type="submit" class="btn btn-dark btn-lg flex-grow-1 rounded-pill fw-bold">
                            <i class="bi bi-plus-lg me-1"></i> Зберегти бренд
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}