@model StepStyle.Web.Models.Brand
@using StepStyle.Web.Models.DTOs

@{
    ViewData["Title"] = Model.Name;
    var detailsController = User.IsInRole("Admin") ? "Product" : "Catalog";
    var countryInfo = ViewBag.CountryInfo as CountryDto;
}

<header class="bg-dark py-4 mb-5 shadow-sm">
    <div class="container px-4 px-lg-5 my-2">
        <div class="text-center text-white">
            <h1 class="display-5 fw-bolder text-uppercase mb-2">@Model.Name</h1>

            <div class="d-flex justify-content-center align-items-center gap-2 mb-3">
                @if (countryInfo != null)
                {
                    <div class="badge bg-light text-dark rounded-pill px-3 py-2 d-flex align-items-center shadow-sm">
                        @if (countryInfo.Flags?.Png != null)
                        {
                            <img src="@countryInfo.Flags.Png" alt="Flag" style="width: 20px; height: auto;" class="me-2 rounded-1" />
                        }
                        <span class="small fw-bold">@countryInfo.Name?.Common</span>

                        @if (countryInfo.Currencies != null && countryInfo.Currencies.Any())
                        {
                            <span class="ms-1 text-muted small">
                                (@string.Join(", ", countryInfo.Currencies.Select(c => c.Value.Symbol)))
                            </span>
                        }
                    </div>
                }
                else if (!string.IsNullOrEmpty(Model.Country))
                {
                    <span class="badge border border-light rounded-pill px-3 py-2 small">
                        <i class="bi bi-geo-alt me-1"></i> @Model.Country
                    </span>
                }
            </div>

            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-white-50 text-decoration-none small">Каталог брендів</a></li>
                    <li class="breadcrumb-item active text-white small" aria-current="page">@Model.Name</li>
                </ol>
            </nav>
        </div>
    </div>
</header>

<div class="container px-4 px-lg-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold m-0">Колекція бренду</h2>
        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-dark btn-sm rounded-pill px-4">
                    <i class="bi bi-pencil me-1"></i> Редагувати бренд
                </a>
                <a asp-controller="Product" asp-action="Create" asp-route-brandId="@Model.Id" class="btn btn-dark btn-sm rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Додати нову пару
                </a>
            </div>
        }
    </div>

    @if (Model.Products != null && Model.Products.Any())
    {
        <div class="row gx-4 gx-lg-5 row-cols-1 row-cols-md-3 row-cols-xl-4 justify-content-start">
            @foreach (var product in Model.Products)
            {
                var mainImg = product.Images?.FirstOrDefault(i => i.IsMain) ?? product.Images?.FirstOrDefault();

                <div class="col mb-5">
                    <div class="card h-100 shadow-sm border-0 product-card overflow-hidden">
                        <div class="position-relative">
                            <a asp-controller="@detailsController" asp-action="Details" asp-route-id="@product.Id">
                                @if (mainImg != null && !string.IsNullOrEmpty(mainImg.ImageUrl))
                                {
                                    <img src="@mainImg.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light text-center py-5" style="height: 200px;">
                                        <i class="bi bi-image text-muted opacity-25" style="font-size: 4rem;"></i>
                                    </div>
                                }
                            </a>
                            <span class="badge bg-dark position-absolute top-0 end-0 m-3 px-3 py-2 rounded-pill shadow-sm">@product.Gender</span>
                        </div>

                        <div class="card-body p-4 text-center">
                            <div class="small text-muted mb-1">Арт: @product.SKU</div>
                            <h5 class="fw-bolder mb-2">@product.Name</h5>
                            <div class="fs-5 fw-bold text-dark">@product.Price ₴</div>
                        </div>

                        <div class="card-footer p-4 pt-0 border-top-0 bg-transparent text-center">
                            <div class="d-grid gap-2">
                                <a asp-controller="@detailsController" asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-dark rounded-pill shadow-sm btn-sm fw-bold">
                                    Детальніше
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-2">
                                        <a asp-controller="Product" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-warning btn-sm flex-grow-1 rounded-pill">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id" method="post" class="flex-grow-1">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-sm w-100 rounded-pill" onclick="return confirm('Видалити @product.Name?');">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-4 border border-dashed">
            <i class="bi bi-emoji-neutral text-muted" style="font-size: 3rem;"></i>
            <h3 class="text-muted mt-3">У цього бренду ще немає товарів</h3>
            <p class="text-secondary">Будьте першим, хто додасть круту пару взуття!</p>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Product" asp-action="Create" asp-route-brandId="@Model.Id" class="btn btn-dark btn-lg rounded-pill px-5 shadow-sm mt-3">
                    <i class="bi bi-plus-lg me-2"></i> Додати першу пару
                </a>
            }
        </div>
    }
</div>

<style>
    .product-card {
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important;
        }

    .breadcrumb-item + .breadcrumb-item::before {
        color: rgba(255,255,255,0.5);
    }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
    }
</style>