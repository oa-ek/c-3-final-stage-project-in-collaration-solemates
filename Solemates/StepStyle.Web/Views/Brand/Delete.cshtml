@model StepStyle.Web.Models.Brand

@{
    ViewData["Title"] = "Видалення бренду";
}

<div class="container my-4">
    <div class="alert alert-danger">
        <h3>Ви впевнені, що хочете видалити цей бренд?</h3>
        <p>Ця дія незворотна. Бренд <strong>@Model.Name</strong> буде повністю видалено з бази.</p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p><strong>Назва:</strong> @Model.Name</p>
            <p><strong>ID бренду:</strong> @Model.Id</p>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Так, видалити</button>
        <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
    </form>
</div>