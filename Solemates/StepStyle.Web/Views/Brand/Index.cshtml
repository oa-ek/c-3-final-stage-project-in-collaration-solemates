@model IEnumerable<StepStyle.Web.Models.Brand>

@{
    ViewData["Title"] = "Каталог брендів";
}

<header class="bg-dark py-5 mb-5 shadow">
    <div class="container px-4 px-lg-5 my-5">
        <div class="text-center text-white">
            <h1 class="display-4 fw-bolder text-uppercase">Крок до стилю</h1>
            <p class="lead fw-normal text-white-50 mb-0">Тільки оригінальне взуття від StepStyle</p>
        </div>
    </div>
</header>

<div class="container px-4 px-lg-5">
    <div class="row">
        <div class="col-lg-3">
            <h4 class="mb-3 fw-bold text-uppercase small text-muted">Фільтр брендів</h4>
            <div class="list-group shadow-sm sticky-top" style="top: 20px;">
                <a href="#" class="list-group-item list-group-item-action active bg-dark border-dark">
                    Усі бренди (@Model.Count())
                </a>
                @foreach (var brand in Model)
                {
                    <a href="#brand-@brand.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        @brand.Name
                        <span class="badge rounded-pill bg-light text-dark border">@(brand.Products?.Count ?? 0)</span>
                    </a>
                }
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="mt-4 d-grid">
                    <a asp-action="Create" class="btn btn-dark fw-bold shadow-sm">+ Додати бренд</a>
                </div>
            }
        </div>

        <div class="col-lg-9">
            <h2 class="mb-4 fw-bold">Наші партнери</h2>

            @foreach (var brand in Model)
            {
                <div id="brand-@brand.Id" class="card mb-5 shadow-sm border-0 overflow-hidden brand-card">
                    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                        <h3 class="h4 m-0 fw-bold">@brand.Name</h3>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@brand.Id" class="btn btn-sm btn-outline-warning text-dark me-2">Редагувати</a>
                                <a asp-action="Delete" asp-route-id="@brand.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                            </div>
                        }
                    </div>

                    <div class="card-body p-0">
                        <div class="row g-0">
                            <div class="col-md-8 p-4">
                                <h6 class="text-uppercase small fw-bold text-muted mb-3 border-bottom pb-2">Популярні моделі:</h6>

                                @if (brand.Products != null && brand.Products.Any())
                                {
                                    <div class="list-group list-group-flush">
                                        @foreach (var product in brand.Products.Take(3))
                                        {
                                            <div class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent border-0 mb-2">
                                                <div>
                                                    <span class="fw-bold">@product.Name</span>
                                                    <span class="badge bg-light text-success border ms-2">@product.Price ₴</span>
                                                </div>
                                                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-link text-decoration-none p-0">Переглянути</a>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <a asp-action="Details" asp-route-id="@brand.Id" class="btn btn-dark btn-sm rounded-pill px-4">
                                            Усі товари бренду (@brand.Products.Count)
                                        </a>
                                    </div>
                                }
                                else
                                {
                                <div class="py-4 text-center bg-light rounded border border-dashed">
                                    <p class="text-muted m-0 small mb-2 italic">Товари скоро з'являться</p>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-controller="Product" asp-action="Create" asp-route-brandId="@brand.Id" class="btn btn-sm btn-outline-dark rounded-pill shadow-sm">
                                            <i class="bi bi-plus-lg me-1"></i> Додати перший товар
                                        </a>
                                    }
                                </div>
                                }
                            </div>

                            <div class="col-md-4 bg-light d-flex flex-column align-items-center justify-content-center py-4 border-start">
                                <div class="mb-2 shadow-sm bg-white rounded-circle d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                    <img src="~/images/brands/brand_@(brand.Id).jpg"
                                         class="rounded-circle p-2"
                                         style="width: 100%; height: 100%; object-fit: contain;"
                                         onerror="this.src='https://via.placeholder.com/100?text=@brand.Name[0]'" />
                                </div>
                                <span class="text-muted small fw-bold mt-2">@brand.Name Official</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .brand-card {
        transition: transform 0.2s ease-in-out, shadow 0.2s;
    }

        .brand-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
        }

    .list-group-item.active {
        background-color: #212529 !important;
        border-color: #212529 !important;
    }
</style>