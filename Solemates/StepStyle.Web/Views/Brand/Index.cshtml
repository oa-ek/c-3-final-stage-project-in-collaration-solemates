@model IEnumerable<StepStyle.Web.Models.Brand>

@{
    ViewData["Title"] = "Каталог брендів";
}

<div class="container-fluid my-4">
    <div class="row">
        <div class="col-md-3 border-end">
            <h4 class="mb-3">📁 Каталог</h4>
            <div class="list-group shadow-sm">
                <a href="#" class="list-group-item list-group-item-action active bg-primary">
                    Усі бренди (@Model.Count())
                </a>
                @foreach (var brand in Model)
                {
                    <a href="#brand-@brand.Id" class="list-group-item list-group-item-action">
                        @brand.Name
                    </a>
                }
            </div>

            <div class="mt-4 d-grid">
                <a asp-action="Create" class="btn btn-outline-primary fw-bold shadow-sm">➕ Додати новий бренд</a>
            </div>
        </div>

        <div class="col-md-9 ps-md-4">
            <h1 class="mb-4">Наші бренди</h1>

            @foreach (var brand in Model)
            {
                <div id="brand-@brand.Id" class="card mb-4 shadow-sm border-primary">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <h2 class="h5 m-0 text-primary fw-bold">@brand.Name (ID: @brand.Id)</h2>
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@brand.Id" class="btn btn-sm btn-outline-warning text-dark me-2">✏️ Редагувати</a>
                            <a asp-action="Delete" asp-route-id="@brand.Id" class="btn btn-sm btn-outline-danger">🗑️ Видалити</a>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="m-0 fw-bold">Товари цього бренду:</h6>
                                    <a asp-controller="Product" asp-action="Create" asp-route-brandId="@brand.Id" class="btn btn-sm btn-success">
                                        ➕ Додати товар
                                    </a>
                                </div>

                                @if (brand.Products.Any())
                                {
                                    <ul class="list-group list-group-flush border rounded">
                                        @foreach (var product in brand.Products)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                @product.Name
                                                <span class="badge bg-success rounded-pill">@product.Price грн.</span>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <div class="alert alert-light border shadow-sm">
                                        <p class="text-muted m-0 italic">У цього бренду поки немає товарів. Будьте першим, хто їх додасть!</p>
                                    </div>
                                }
                            </div>

                            <div class="col-md-4 text-center border-start d-flex align-items-center justify-content-center bg-light rounded-end">
                                <span class="text-muted small px-3">Тут у майбутньому може бути логотип бренду <strong>@brand.Name</strong></span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>