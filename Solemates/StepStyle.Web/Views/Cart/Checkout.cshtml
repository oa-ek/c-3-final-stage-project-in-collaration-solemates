@model StepStyle.Web.Models.DTOs.CheckoutDto

@{
    ViewData["Title"] = "Оформлення замовлення";
}

<div class="container mt-5">
    <h2>Оформлення замовлення</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Checkout" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="ShippingAddress" class="control-label">Адреса доставки</label>
                    <input asp-for="ShippingAddress" class="form-control" placeholder="Місто, відділення Нової Пошти..." required />
                    <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DeliveryMethod" class="control-label">Спосіб доставки</label>
                    <select asp-for="DeliveryMethod" class="form-control">
                        <option value="Нова Пошта">Нова Пошта</option>
                        <option value="Укрпошта">Укрпошта</option>
                        <option value="Самовивіз">Самовивіз</option>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="PaymentMethod" class="control-label">Спосіб оплати</label>
                    <select asp-for="PaymentMethod" class="form-control">
                        <option value="При отриманні">Оплата при отриманні</option>
                        <option value="Карткою">Карткою на сайті</option>
                    </select>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-success btn-lg">Підтвердити замовлення</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg ms-2">Повернутися до кошика</a>
                </div>
            </form>
        </div>
    </div>
</div>