@model StepStyle.Web.Models.Cart

@{
    ViewData["Title"] = "Мій кошик";
}

<div class="container my-5">
    <h1 class="fw-bold mb-4"><i class="bi bi-cart3 text-primary"></i> Кошик</h1>

    @if (Model != null && Model.CartItems != null && Model.CartItems.Any())
    {
        <div class="row">
            <div class="col-lg-8">
                @foreach (var item in Model.CartItems)
                {
                    <div class="card shadow-sm border-0 mb-3 p-3">
                        <div class="row align-items-center">

                            <div class="col-md-2 col-4">
                                <img src="@(item.ProductVariant?.Product?.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png")"
                                     class="img-fluid rounded shadow-sm" alt="product" style="object-fit: cover; height: 80px; width: 100%;">
                            </div>


                            <div class="col-md-4 col-8">
                                <h6 class="fw-bold mb-1">@item.ProductVariant?.Product?.Name</h6>
                                <span class="badge bg-light text-dark border rounded-pill">
                                    Розмір: @item.ProductVariant?.Size?.Value
                                </span>
                            </div>

 
                            <div class="col-md-2 col-4 text-center">
                                <span class="text-muted d-block d-md-none">Кількість:</span>
                                <span class="fw-bold">@item.Quantity шт.</span>
                            </div>


                            <div class="col-md-2 col-4 text-center text-md-start">
                                <span class="text-muted d-block d-md-none">Сума:</span>
                                <span class="fw-bold text-primary">
                                    @((item.ProductVariant?.Product?.Price ?? 0) * item.Quantity) грн.
                                </span>
                            </div>


                            <div class="col-md-2 col-4 text-end">
                                <form asp-controller="Cart" asp-action="RemoveFromCart" method="post">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle" title="Видалити">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 p-4 bg-light position-sticky" style="top: 20px;">
                    <h5 class="fw-bold mb-3">Підсумок замовлення</h5>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="text-muted">Загальна сума:</span>
                        <span class="fw-bold text-primary" style="font-size: 1.5rem;">
                            @Model.CartItems.Sum(x => (x.ProductVariant?.Product?.Price ?? 0) * x.Quantity) грн.
                        </span>
                    </div>

                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-dark btn-lg w-100 rounded-pill fw-bold shadow-sm">
                        Оформити замовлення
                    </a>

                    <a href="/" class="btn btn-link btn-sm w-100 text-secondary mt-2 text-decoration-none">
                        <i class="bi bi-arrow-left"></i> Продовжити покупки
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white rounded shadow-sm border">
            <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
            <h3 class="mt-3 fw-bold">Ваш кошик порожній</h3>
            <p class="text-secondary">Час додати туди щось стильне!</p>
            <a href="/" class="btn btn-primary mt-3 px-5 py-2 rounded-pill fw-bold shadow">
                Перейти до каталогу
            </a>
        </div>
    }
</div>