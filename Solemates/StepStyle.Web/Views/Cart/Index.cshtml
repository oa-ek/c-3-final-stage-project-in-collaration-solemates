@model StepStyle.Web.Models.Cart

@{
    ViewData["Title"] = "Кошик";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8">
            <h5 class="text-uppercase mb-4 fw-bold text-secondary" style="letter-spacing: 1px;">Товари в замовленні</h5>
            
            @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
            {
                <div class="alert alert-info py-4 text-center shadow-sm rounded-3">
                    <h5 class="mb-2">Тут поки що порожньо 🛍️</h5>
                    <p class="text-muted mb-3">Додайте товари з каталогу, щоб почати оформлення замовлення.</p>
                    <a asp-controller="Catalog" asp-action="Index" class="btn btn-dark px-4 rounded-pill">Перейти до каталогу</a>
                </div>
            }
            else
            {
                @foreach (var item in Model.CartItems)
                {
                    var product = item.ProductVariant?.Product;
                    var size = item.ProductVariant?.Size;
                    var imageUrl = product?.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

                    <div class="card mb-3 border-0 shadow-sm rounded-3 overflow-hidden">
                        <div class="card-body p-3">
                            <div class="row align-items-center">
                                <div class="col-md-2 text-center">
                                    <img src="@imageUrl" alt="@product?.Name" class="img-fluid rounded-3" style="max-height: 80px; object-fit: contain;" />
                                </div>
                                <div class="col-md-5">
                                    <h6 class="fw-bold mb-1">@product?.Name</h6>
                                    <p class="text-muted small mb-1">Розмір: <strong class="text-dark">@size?.Value</strong></p>
                                    <p class="text-muted small mb-0">Ціна: @product?.Price.ToString("F1") ₴</p>
                                </div>
                                <div class="col-md-2 text-center">
                                    <span class="badge bg-light text-dark border px-3 py-2 rounded-3">@item.Quantity шт.</span>
                                </div>
                                <div class="col-md-3 text-end">
                                    <div class="fw-bold mb-2">@((product?.Price * item.Quantity)?.ToString("F1")) ₴</div>
                                    <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                        <input type="hidden" name="cartItemId" value="@item.Id" />
                                        <button type="submit" class="btn btn-link text-danger text-decoration-none p-0 small">Видалити</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 rounded-4" style="background-color: #fff;">
                <h4 class="fw-bold mb-4">Деталі замовлення</h4>
                
                @{
                    var totalItems = Model?.CartItems?.Sum(i => i.Quantity) ?? 0;
                    var totalPrice = Model?.CartItems?.Sum(i => (i.ProductVariant?.Product?.Price ?? 0) * i.Quantity) ?? 0;
                }

                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Товарів:</span>
                    <span class="fw-bold">@totalItems</span>
                </div>
                
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Доставка:</span>
                    <span class="text-success fw-bold text-uppercase small">Безкоштовно</span>
                </div>
                
                <hr class="my-3" style="border-top: 1px dashed #dee2e6;" />
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="fw-bold fs-5">Разом:</span>
                    <span class="fw-bold fs-4 text-dark">@totalPrice.ToString("F1") ₴</span>
                </div>

                @if (totalItems > 0)
                {
                    <a asp-controller="Cart" asp-action="Checkout" class="btn btn-dark w-100 py-3 rounded-pill fw-bold mb-2 shadow-sm text-center text-white text-decoration-none d-block" style="background-color: #1a1e21;">
                        Оформити замовлення
                    </a>
                }
                else
                {
                    <button class="btn btn-secondary w-100 py-3 rounded-pill fw-bold mb-2 disabled">
                        Кошик порожній
                    </button>
                }

                <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-secondary w-100 py-3 rounded-pill fw-bold btn-sm text-center text-decoration-none d-block">
                    ← Продовжити покупки
                </a>
            </div>
        </div>
    </div>
</div>