@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-3">
            <a class="nav-link text-dark position-relative" asp-controller="Wishlist" asp-action="Index" title="Улюблені">
                <i class="bi bi-heart" style="font-size: 1.25rem; -webkit-text-stroke: 0.5px red;"></i>
            </a>
        </li>

        <li class="nav-item me-4">
            <a class="nav-link text-dark" asp-controller="Cart" asp-action="Index" title="Кошик">
                <i class="bi bi-bag" style="font-size: 1.25rem;"></i>
            </a>
        </li>

        <li class="nav-item me-3">
            <a class="nav-link text-dark fw-semibold d-flex align-items-center gap-1 border-bottom border-dark pb-1" asp-area="Identity" asp-page="/Account/Manage/Index" title="Мій Кабінет">
                <i class="bi bi-person-circle" style="font-size: 1.1rem;"></i>
                <span>Кабінет</span>
            </a>
        </li>

        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Brand", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-muted border-0 bg-transparent small text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">Вийти</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item me-2">
            <a class="nav-link text-dark small text-uppercase fw-semibold" style="letter-spacing: 1px;" asp-area="Identity" asp-page="/Account/Login">Вхід</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-outline-dark btn-sm rounded-pill px-3 text-uppercase fw-semibold" style="font-size: 0.75rem; letter-spacing: 1px;" asp-area="Identity" asp-page="/Account/Register">Реєстрація</a>
        </li>
    }
</ul>