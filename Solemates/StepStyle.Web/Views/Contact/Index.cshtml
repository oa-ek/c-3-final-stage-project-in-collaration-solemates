@model StepStyle.Web.Models.ContactMessage

@{
    ViewData["Title"] = "Зворотний зв'язок";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <h2 class="text-center fw-bold mb-4">Напишіть нам</h2>
                    <p class="text-center text-muted mb-4">Маєте питання щодо доставки, розмірів чи наявності товару? Заповніть форму нижче, і наша команда з радістю вам допоможе!</p>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success text-center fw-medium rounded-3 py-3">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="Index" method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-semibold">Ваше ім'я</label>
                                <input asp-for="Name" class="form-control form-control-lg bg-light" placeholder="Іван Іванов" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label asp-for="Email" class="form-label fw-semibold">Ваш Email</label>
                                <input asp-for="Email" class="form-control form-control-lg bg-light" placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label fw-semibold">Тема (необов'язково)</label>
                            <input asp-for="Subject" class="form-control form-control-lg bg-light" placeholder="Наприклад: Доставка в Польщу" />
                            <span asp-validation-for="Subject" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Message" class="form-label fw-semibold">Повідомлення</label>
                            <textarea asp-for="Message" class="form-control form-control-lg bg-light" rows="5" placeholder="Напишіть ваше запитання тут..."></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark btn-lg rounded-pill fw-bold">Надіслати повідомлення</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}