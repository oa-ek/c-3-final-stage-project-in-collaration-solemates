@model IEnumerable<StepStyle.Web.Models.ContactMessage>

@{
    ViewData["Title"] = "Мої звернення";
}

<div class="container mt-5" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Історія моїх запитів</h2>
        <a asp-action="Index" class="btn btn-dark rounded-pill px-4">Нове запитання</a>
    </div>
    <hr />

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center py-5 rounded-4 shadow-sm bg-white border">
            <i class="bi bi-envelope-open text-muted fs-1 mb-3 d-block"></i>
            <h5 class="fw-bold mb-2">Ви ще не надсилали запитів</h5>
            <p class="text-muted mb-0">Усі ваші майбутні звернення та відповіді адміністрації відображатимуться на цій сторінці.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 mb-4">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden border-start border-3 @(!string.IsNullOrEmpty(item.AdminReply) ? "border-success" : "border-warning")">
                        <div class="card-header bg-light border-0 py-3 d-flex justify-content-between align-items-center">
                            <div>
                                <span class="text-muted small">Створено:</span>
                                <strong class="text-dark ms-1">@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                            </div>
                            <div>
                                @if (!string.IsNullOrEmpty(item.AdminReply))
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-3 py-2 rounded-pill">
                                        <i class="bi bi-check-circle-fill me-1"></i> Отримано відповідь
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20 px-3 py-2 rounded-pill">
                                        <i class="bi bi-hourglass-split me-1"></i> Очікує на розгляд
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="card-body p-4 bg-white">
                            <div class="mb-2">
                                <span class="badge bg-secondary mb-2 px-2 py-1 rounded small text-uppercase" style="font-size: 10px;">Ваше запитання</span>
                                @if (!string.IsNullOrEmpty(item.Subject))
                                {
                                    <h6 class="fw-bold text-dark mb-2">Тема: @item.Subject</h6>
                                }
                                <p class="text-muted p-3 bg-light rounded-3 mb-0" style="white-space: pre-line;">@item.Message</p>
                            </div>

                            @if (!string.IsNullOrEmpty(item.AdminReply))
                            {
                                <div class="mt-4 pt-3 border-top border-light">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="badge bg-success px-2 py-1 rounded small text-uppercase" style="font-size: 10px;">Відповідь менеджера</span>
                                        <small class="text-muted">@item.RepliedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                    </div>
                                    <p class="text-dark p-3 rounded-3 mb-0 fw-medium" style="background-color: #f4fbf7; border-left: 4px solid #198754; white-space: pre-line;">
                                        @item.AdminReply
                                    </p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>