@model StepStyle.Web.Models.ContactMessage

@{
    ViewData["Title"] = "Відповідь клієнту";
}

<style>
    .admin-card {
        background-color: #ffffff;
        border: 1px solid #e5e5e5 !important;
        border-radius: 12px !important;
    }

    .admin-card-header {
        background-color: #fafafa !important;
        border-bottom: 1px solid #e5e5e5 !important;
        padding: 1.25rem !important;
    }

    .form-control-custom {
        border: 1px solid #dee2e6 !important;
        border-radius: 8px !important;
        padding: 0.75rem 1rem !important;
        font-size: 0.95rem !important;
        resize: vertical;
    }

        .form-control-custom:focus {
            border-color: #212529 !important;
            box-shadow: 0 0 0 1px #212529 !important;
        }

    .btn-black-custom {
        background-color: #212529 !important;
        color: #ffffff !important;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: background-color 0.2s ease;
    }

        .btn-black-custom:hover {
            background-color: #495057 !important;
            color: #ffffff !important;
        }

    .alert-info-custom {
        background-color: #f8f9fa !important;
        border: 1px solid #dee2e6 !important;
        color: #212529 !important;
    }
</style>

<div class="container mt-5" style="max-width: 1200px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-dark" style="letter-spacing: -0.5px;">Відповідь на запит від @Model.Name</h2>
        <a asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-medium">
            <i class="bi bi-arrow-left me-1"></i> Назад до списку
        </a>
    </div>
    <hr class="text-muted opacity-20 mb-4" />

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card admin-card shadow-sm h-100">
                <div class="card-header admin-card-header rounded-top-12">
                    <h5 class="mb-0 fw-bold text-dark" style="font-size: 1rem;">
                        </i>Дані клієнта
                    </h5>
                </div>
                <div class="card-body p-4 text-secondary" style="font-size: 0.95rem; line-height: 1.8;">
                    <p class="mb-2"><strong class="text-dark">Ім'я:</strong> @Model.Name</p>
                    <p class="mb-2">
                        <strong class="text-dark">Email:</strong>
                        <a href="mailto:@Model.Email" class="text-decoration-none text-dark fw-medium border-bottom border-dark border-1">@Model.Email</a>
                    </p>
                    <p class="mb-2"><strong class="text-dark">Дата запиту:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    <p class="mb-4"><strong class="text-dark">Тема:</strong> @(string.IsNullOrEmpty(Model.Subject) ? "—" : Model.Subject)</p>

                    <div class="pt-3 border-top border-light">
                        <span class="text-uppercase fw-bold text-muted d-block mb-2" style="font-size: 0.65rem; letter-spacing: 0.5px;">Повідомлення клієнта</span>
                        <div class="p-3 bg-light rounded-3 text-dark border-0 style-plain" style="font-size: 0.95rem; white-space: pre-line; background-color: #fbfbfb !important; border: 1px solid #f1f1f1 !important;">@Model.Message</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card admin-card shadow-sm h-100">
                <div class="card-header admin-card-header rounded-top-12">
                    <h5 class="mb-0 fw-bold text-dark" style="font-size: 1rem;">
                        </i>Написати відповідь
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Reply" method="post" class="h-100 d-flex flex-column justify-content-between">
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        @if (!string.IsNullOrEmpty(Model.AdminReply))
                        {
                            <div class="alert alert-info-custom rounded-3 p-3 mb-4 small">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                <strong>Ви вже відповіли на цей запит (@Model.RepliedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")).</strong>
                                <br /><span class="text-muted">Нижче ви можете відредагувати або повністю оновити поточний текст відповіді.</span>
                            </div>
                        }

                        <div class="form-group mb-4 flex-grow-1">
                            <label for="adminReply" class="small text-uppercase fw-bold text-muted mb-2" style="letter-spacing: 0.5px;">Текст вашої відповіді</label>
                            <textarea id="adminReply" name="adminReply" class="form-control form-control-custom" rows="8" placeholder="Напишіть детальну відповідь для клієнта тут..." required>@Model.AdminReply</textarea>
                        </div>

                        <button type="submit" class="btn btn-black-custom w-100 rounded-pill border-0 shadow-sm py-2-5 mt-auto" style="padding: 0.75rem 0;">
                            <i class="bi bi-send-fill me-2 small"></i> Зберегти відповідь
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>