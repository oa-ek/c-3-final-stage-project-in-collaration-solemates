@model StepStyle.Web.Models.ContactMessage

@{
    ViewData["Title"] = "Відповідь клієнту";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Відповідь на запит від @Model.Name</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Назад до списку</a>
    </div>
    <hr />

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Дані клієнта</h5>
                </div>
                <div class="card-body">
                    <p><strong>Ім'я:</strong> @Model.Name</p>
                    <p><strong>Email:</strong> <a href="mailto:@Model.Email">@Model.Email</a></p>
                    <p><strong>Дата:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    <p><strong>Тема:</strong> @(string.IsNullOrEmpty(Model.Subject) ? "—" : Model.Subject)</p>
                    <div class="mt-4">
                        <strong>Повідомлення клієнта:</strong>
                        <div class="p-3 bg-light rounded border mt-2">
                            @Model.Message
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card shadow-sm h-100 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Написати відповідь</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Reply" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        @if (!string.IsNullOrEmpty(Model.AdminReply))
                        {
                            <div class="alert alert-info">
                                <strong>Ви вже відповіли на цей запит (@Model.RepliedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")).</strong><br />
                                Ви можете відредагувати/оновити свою відповідь нижче.
                            </div>
                        }

                        <div class="mb-3">
                            <label for="adminReply" class="form-label fw-bold">Текст вашої відповіді:</label>
                            <textarea id="adminReply" name="adminReply" class="form-control" rows="8" placeholder="Напишіть вашу відповідь тут..." required>@Model.AdminReply</textarea>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100">
                            <i class="bi bi-send me-2"></i> Зберегти відповідь
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>