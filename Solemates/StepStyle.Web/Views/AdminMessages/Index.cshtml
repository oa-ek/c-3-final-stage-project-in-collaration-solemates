@model IEnumerable<StepStyle.Web.Models.ContactMessage>

@{
    ViewData["Title"] = "Запити від клієнтів";
}

<div class="container mt-4">
    <h2 class="mb-3">Запити від клієнтів (Зворотний зв'язок)</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="table-responsive shadow-sm rounded-3">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Дата</th>
                    <th>Клієнт</th>
                    <th>Тема</th>
                    <th>Повідомлення</th>
                    <th>Статус</th>
                    <th>Дії</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsRead ? "text-muted" : "fw-bold")">
                        <td style="white-space: nowrap;">@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <div>@item.Name</div>
                            <small class="text-secondary">@item.Email</small>
                        </td>
                        <td>@(string.IsNullOrEmpty(item.Subject) ? "—" : item.Subject)</td>
                        <td style="max-width: 250px;">
                            <div style="max-height: 60px; overflow-y: auto;">
                                @item.Message
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.AdminReply))
                            {
                                <span class="badge bg-success">Надано відповідь</span>
                            }
                            else if (item.IsRead)
                            {
                                <span class="badge bg-secondary">Прочитано</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Нове</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Reply" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-reply"></i> Відповісти
                                </a>
                                
                                @if (!item.IsRead)
                                {
                                    <form asp-action="MarkAsRead" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="Просто позначити прочитаним">
                                            <i class="bi bi-check2"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Поки що немає жодного повідомлення.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>