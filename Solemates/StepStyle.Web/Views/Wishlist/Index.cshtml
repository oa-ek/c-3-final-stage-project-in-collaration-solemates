@model IEnumerable<StepStyle.Web.Models.WishlistItem>

@{
    ViewData["Title"] = "Мої бажанки";
}

<div class="container my-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold"><i class="bi bi-heart-fill text-danger"></i> Список бажань</h1>
        <a href="/" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i> Назад до покупок
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0 p-4">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 150px;">Товар</th>
                            <th>Назва</th>
                            <th>Доступний розмір</th>
                            <th>Ціна</th>
                            <th class="text-center">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var availableVariant = item.Product.Variants?.FirstOrDefault(v => v.QuantityInStock > 0);

                            <tr>
                                <td>
                                    @{
                                        var imgUrl = item.Product.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";
                                    }
                                    <img src="@imgUrl" class="rounded shadow-sm" style="height: 80px; width: 100px; object-fit: cover;" alt="@item.Product.Name" />
                                </td>
                                <td>
                                    <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">
                                        <h6 class="mb-0 fw-bold">@item.Product.Name</h6>
                                    </a>
                                    <small class="text-muted">Артикул: @item.Product.SKU</small>
                                </td>
                                <td>
                                    @if (availableVariant != null)
                                    {
                                        <span class="badge bg-dark rounded-pill">Розмір: @availableVariant.Size?.Value</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">Немає в наявності</span>
                                    }
                                </td>
                                <td>
                                    <span class="fw-bold text-dark">@item.Product.Price грн.</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">

                                        <form asp-controller="Wishlist" asp-action="MoveToCart" method="post" style="display:inline;">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary px-3"
                                                    title="Додати в кошик" @(availableVariant == null ? "disabled" : "")>
                                                <i class="bi bi-cart-plus"></i>
                                            </button>
                                        </form>

                                        <form asp-controller="Wishlist" asp-action="Remove" method="post" style="display:inline;">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3" title="Видалити">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <form asp-controller="Wishlist" asp-action="AddAllToCart" method="post">
                    <button type="submit" class="btn btn-danger btn-lg px-4 rounded-pill fw-bold shadow-sm">
                        <i class="bi bi-cart-check"></i> Додати все до кошика
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 border rounded bg-white shadow-sm">
            <i class="bi bi-heartbreak text-muted" style="font-size: 4rem;"></i>
            <h3 class="mt-3 text-muted">Ваш список бажань порожній</h3>
            <p class="text-secondary">Здається, ви ще не додали жодного товару до списку улюблених.</p>
            <a href="/" class="btn btn-primary px-4 rounded-pill mt-2">
                Перейти до каталогу
            </a>
        </div>
    }
</div>