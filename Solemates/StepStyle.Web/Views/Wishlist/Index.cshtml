@model IEnumerable<StepStyle.Web.Models.WishlistItem>

@{
    ViewData["Title"] = "Мої бажанки";
}

<header class="bg-dark py-4 mb-5 shadow-sm">
    <div class="container px-4 px-lg-5 my-2 text-center">
        <h1 class="display-6 fw-bolder text-white text-uppercase m-0">Список бажань</h1>
        <p class="lead fw-normal text-white-50 mb-0">Твоє улюблене взуття чекає на тебе</p>
    </div>
</header>

<div class="container px-4 px-lg-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-pill px-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row gx-lg-5">
            <div class="col-lg-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold text-uppercase small text-muted m-0">Збережені моделі (@Model.Count())</h4>
                    <form asp-controller="Wishlist" asp-action="AddAllToCart" method="post">
                        <button type="submit" class="btn btn-dark btn-sm rounded-pill px-4 shadow-sm fw-bold">
                            <i class="bi bi-cart-check me-2"></i> Додати все до кошика
                        </button>
                    </form>
                </div>

                @foreach (var item in Model)
                {
                    var availableVariant = item.Product.Variants?.FirstOrDefault(v => v.QuantityInStock > 0);
                    var imgUrl = item.Product.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";

                    <div class="card mb-3 border-0 shadow-sm overflow-hidden wishlist-card">
                        <div class="card-body p-0">
                            <div class="row g-0 align-items-center">
                                <div class="col-4 col-md-2">
                                    <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductId">
                                        <img src="@imgUrl" class="img-fluid" alt="@item.Product.Name" style="height: 120px; width: 100%; object-fit: cover;">
                                    </a>
                                </div>

                                <div class="col-5 col-md-6 ps-4">
                                    <h5 class="fw-bold mb-1">
                                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.ProductId" class="text-dark text-decoration-none">
                                            @item.Product.Name
                                        </a>
                                    </h5>
                                    <div class="mb-2">
                                        @if (availableVariant != null)
                                        {
                                            <span class="badge bg-light text-dark border rounded-pill">Доступний розмір: @availableVariant.Size?.Value</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill opacity-75">Тимчасово відсутній</span>
                                        }
                                    </div>
                                    <div class="fw-bold fs-5 text-dark">@item.Product.Price ₴</div>
                                </div>

                                <div class="col-3 col-md-4 pe-4 text-end">
                                    <div class="d-flex flex-column flex-md-row justify-content-end gap-2">
                                        <form asp-controller="Wishlist" asp-action="MoveToCart" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-outline-dark btn-sm rounded-pill px-3 fw-bold w-100"
                                                    @(availableVariant == null ? "disabled" : "")>
                                                <i class="bi bi-cart-plus me-1"></i> Купити
                                            </button>
                                        </form>

                                        <form asp-controller="Wishlist" asp-action="Remove" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" class="btn btn-link text-danger p-0 small text-decoration-none ms-md-3" title="Видалити">
                                                Прибрати
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-heart text-muted opacity-25" style="font-size: 6rem;"></i>
            </div>
            <h2 class="fw-bold">Список бажань порожній</h2>
            <p class="text-muted mb-4">Додавайте моделі, які вам сподобались, щоб не загубити їх.</p>
            <a href="/" class="btn btn-dark btn-lg px-5 rounded-pill shadow">
                Перейти до каталогу
            </a>
        </div>
    }
</div>

<style>
    .wishlist-card {
        transition: all 0.3s ease;
    }

        .wishlist-card:hover {
            transform: translateX(10px);
            box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.1) !important;
        }

    .alert {
        border: none;
    }
</style>