@model StepStyle.Web.Models.Order

@{
    ViewData["Title"] = $"Замовлення №{Model.Id}";

    var orderStatusesUk = new Dictionary<string, string>
    {
        { "Pending", "В обробці" },
        { "Processing", "Комплектується" },
        { "Shipped", "Відправлено" },
        { "Delivered", "Доставлено" },
        { "Cancelled", "Скасовано" }
    };

    var paymentStatusesUk = new Dictionary<string, string>
    {
        { "Pending", "Очікує оплати" },
        { "Unpaid", "Неоплачено" },
        { "Paid", "Оплачено" },
        { "Failed", "Помилка оплати" },
        { "Refunded", "Повернено кошти" }
    };
}

<style>
    .admin-card {
        background-color: #ffffff;
        border: 1px solid #e5e5e5 !important;
        border-radius: 12px !important;
    }

    .admin-card-header {
        background-color: #fafafa !important;
        border-bottom: 1px solid #e5e5e5 !important;
        padding: 1.25rem !important;
    }

    .form-select-custom {
        border: 1px solid #dee2e6 !important;
        border-radius: 8px !important;
        padding: 0.6rem 1rem !important;
        font-size: 0.95rem !important;
    }

        .form-select-custom:focus {
            border-color: #212529 !important;
            box-shadow: 0 0 0 1px #212529 !important;
        }

    .table-custom th {
        background-color: #fafafa !important;
        color: #212529 !important;
        font-size: 0.75rem !important;
        text-transform: uppercase !important;
        letter-spacing: 0.5px !important;
        font-weight: 700 !important;
        border-bottom: 2px solid #e5e5e5 !important;
    }

    .table-custom td {
        vertical-align: middle !important;
        font-size: 0.95rem;
    }

    .btn-black-custom {
        background-color: #212529 !important;
        color: #ffffff !important;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: background-color 0.2s ease;
    }

        .btn-black-custom:hover {
            background-color: #495057 !important;
        }

    .success-toast {
        border: 1px solid #212529;
        background-color: #fbfbfb;
        color: #212529;
    }
</style>

<div class="container mt-5" style="max-width: 1100px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0 text-dark" style="letter-spacing: -0.5px;">Замовлення №@Model.Id</h2>
        <a asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 btn-sm fw-medium">
            <i class="bi bi-arrow-left me-1"></i> Назад до списку
        </a>
    </div>
    <hr class="text-muted opacity-20 mb-4" />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert success-toast rounded-3 py-3 px-4 mb-4 d-flex align-items-center shadow-sm fw-medium">
            <i class="bi bi-check2-circle fs-5 me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card admin-card shadow-sm h-100">
                <div class="card-header admin-card-header rounded-top-12">
                    <h5 class="mb-0 fw-bold text-dark" style="font-size: 1rem;">
                        <i class="bi bi-info-circle me-2 text-muted"></i>Інформація про доставку
                    </h5>
                </div>
                <div class="card-body p-4 text-secondary" style="font-size: 0.95rem; line-height: 1.8;">
                    <p class="mb-2"><strong class="text-dark">Клієнт:</strong> @(Model.User?.Email ?? "Невідомий")</p>
                    <p class="mb-2"><strong class="text-dark">Дата замовлення:</strong> @Model.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    <p class="mb-2"><strong class="text-dark">Спосіб доставки:</strong> @Model.DeliveryMethod</p>
                    <p class="mb-2"><strong class="text-dark">Адреса доставки:</strong> @Model.ShippingAddress</p>
                    <p class="mb-4"><strong class="text-dark">Спосіб оплати:</strong> @Model.PaymentMethod</p>

                    <div class="pt-3 border-top border-light">
                        <span class="text-uppercase fw-bold text-muted d-block mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">Підсумкова сума до сплати</span>
                        <h4 class="fw-bold text-dark mb-0" style="letter-spacing: -0.5px;">@Model.TotalAmount.ToString("C")</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card admin-card shadow-sm h-100">
                <div class="card-header admin-card-header rounded-top-12">
                    <h5 class="mb-0 fw-bold text-dark" style="font-size: 1rem;">
                        <i class="bi bi-sliders me-2 text-muted"></i>Управління статусами
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="form-group mb-3">
                            <label class="small text-uppercase fw-bold text-muted mb-2" style="letter-spacing: 0.5px;">Статус замовлення (Логістика)</label>
                            <select name="status" class="form-select form-select-custom">
                                @foreach (var stat in Enum.GetValues(typeof(StepStyle.Web.Models.OrderStatus)))
                                {
                                    var statStr = stat.ToString();
                                    var displayStr = orderStatusesUk.ContainsKey(statStr) ? orderStatusesUk[statStr] : statStr;

                                    if (Model.Status.Equals(stat))
                                    {
                                        <option value="@stat" selected>@displayStr</option>
                                    }
                                    else
                                    {
                                        <option value="@stat">@displayStr</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group mb-4">
                            <label class="small text-uppercase fw-bold text-muted mb-2" style="letter-spacing: 0.5px;">Статус оплати (Фінанси)</label>
                            <select name="paymentStatus" class="form-select form-select-custom">
                                @foreach (var pStat in Enum.GetValues(typeof(StepStyle.Web.Models.PaymentStatus)))
                                {
                                    var pStatStr = pStat.ToString();
                                    var displayPaymentStr = paymentStatusesUk.ContainsKey(pStatStr) ? paymentStatusesUk[pStatStr] : pStatStr;

                                    if (Model.PaymentStatus.Equals(pStat))
                                    {
                                        <option value="@pStat" selected>@displayPaymentStr</option>
                                    }
                                    else
                                    {
                                        <option value="@pStat">@displayPaymentStr</option>
                                    }
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-black-custom w-100 rounded-pill border-0 shadow-sm mt-2" style="padding: 0.65rem 0;">
                            Оновити статуси
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold text-dark mt-4 mb-3" style="font-size: 1.2rem; letter-spacing: -0.3px;">Склад замовлення</h4>
    <div class="card admin-card shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Товар</th>
                        <th class="text-center">Розмір</th>
                        <th class="text-end">Ціна одиниці</th>
                        <th class="text-center">Кількість</th>
                        <th class="text-end pe-4">Сума</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td class="fw-semibold text-dark ps-4">
                                @(item.ProductVariant?.Product?.Name ?? "Товар видалено з каталогу")
                            </td>
                            <td class="text-center text-secondary">
                                <span class="badge bg-light text-dark border px-2 py-1" style="font-size: 0.85rem;">
                                    @(item.ProductVariant?.Size?.Value ?? "-")
                                </span>
                            </td>
                            <td class="text-end text-secondary">@item.PriceAtPurchase.ToString("C")</td>
                            <td class="text-center text-dark fw-medium">@item.Quantity шт.</td>
                            <td class="text-end fw-bold text-dark pe-4">@((item.PriceAtPurchase * item.Quantity).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>