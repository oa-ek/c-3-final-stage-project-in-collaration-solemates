@model StepStyle.Web.Models.Order

@{
    ViewData["Title"] = $"Замовлення №{Model.Id}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Деталі замовлення №@Model.Id</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">← Назад до списку</a>
    </div>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Інформація про доставку</h5>
                </div>
                <div class="card-body">
                    <p><strong>Клієнт:</strong> @(Model.User?.Email ?? "Невідомий")</p>
                    <p><strong>Дата замовлення:</strong> @Model.OrderDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    <p><strong>Спосіб доставки:</strong> @Model.DeliveryMethod</p>
                    <p><strong>Адреса доставки:</strong> @Model.ShippingAddress</p>
                    <p><strong>Спосіб оплати:</strong> @Model.PaymentMethod</p>
                    <h5 class="mt-3 text-success">Загальна сума: @Model.TotalAmount.ToString("C")</h5>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Управління статусами</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="form-group mb-3">
                            <label class="fw-bold">Статус замовлення (Логістика)</label>
                            <select name="status" class="form-select mt-1">
                                @foreach (var stat in Enum.GetValues(typeof(StepStyle.Web.Models.OrderStatus)))
                                {
                                    if (Model.Status.Equals(stat))
                                    {
                                        <option value="@stat" selected>@stat</option>
                                    }
                                    else
                                    {
                                        <option value="@stat">@stat</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="fw-bold">Статус оплати (Фінанси)</label>
                            <select name="paymentStatus" class="form-select mt-1">
                                @foreach (var pStat in Enum.GetValues(typeof(StepStyle.Web.Models.PaymentStatus)))
                                {
                                    if (Model.PaymentStatus.Equals(pStat))
                                    {
                                        <option value="@pStat" selected>@pStat</option>
                                    }
                                    else
                                    {
                                        <option value="@pStat">@pStat</option>
                                    }
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Оновити статуси</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mt-4">Куплені товари</h4>
    <div class="table-responsive">
        <table class="table table-bordered mt-2">
            <thead class="table-light">
                <tr>
                    <th>Товар</th>
                    <th>Розмір</th>
                    <th>Ціна за одиницю</th>
                    <th>Кількість</th>
                    <th>Сума</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td>@(item.ProductVariant?.Product?.Name ?? "Товар видалено")</td>
                        <td>@(item.ProductVariant?.Size?.Value ?? "-")</td>
                        <td>@item.PriceAtPurchase.ToString("C")</td>
                        <td>@item.Quantity шт.</td>
                        <td>@((item.PriceAtPurchase * item.Quantity).ToString("C"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>