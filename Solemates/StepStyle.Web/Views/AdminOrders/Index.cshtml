@model IEnumerable<StepStyle.Web.Models.Order>

@{
    ViewData["Title"] = "Управління замовленнями";

    var orderStatusesUk = new Dictionary<string, string>
    {
        { "Pending", "В обробці" },
        { "Processing", "Комплектується" },
        { "Shipped", "Відправлено" },
        { "Delivered", "Доставлено" },
        { "Cancelled", "Скасовано" }
    };

    var paymentStatusesUk = new Dictionary<string, string>
    {
        { "Unpaid", "Неоплачено" },
        { "Paid", "Оплачено" },
        { "Refunded", "Повернено" }
    };
}

<style>
    .table-container {
        background-color: #ffffff;
        border: 1px solid #e5e5e5 !important;
        border-radius: 12px !important;
    }

    .table-admin-list th {
        background-color: #fafafa !important;
        color: #212529 !important;
        font-size: 0.75rem !important;
        text-transform: uppercase !important;
        letter-spacing: 0.5px !important;
        font-weight: 700 !important;
        padding: 1rem 0.75rem !important;
        border-bottom: 2px solid #e5e5e5 !important;
    }

    .table-admin-list td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle !important;
        font-size: 0.9rem;
        color: #495057;
    }

    .badge-order {
        font-size: 0.75rem !important;
        font-weight: 600 !important;
        padding: 5px 10px !important;
        border-radius: 6px !important;
        display: inline-block;
        text-align: center;
    }

    .badge-pay-Pending, .badge-pay-Unpaid {
        background-color: #fff3cd !important;
        color: #856404 !important;
        border: 1px solid #ffeeba !important;
    }

    .badge-pay-Paid {
        background-color: #d4edda !important;
        color: #155724 !important;
        border: 1px solid #c3e6cb !important;
    }

    .badge-pay-Failed {
        background-color: #f8d7da !important;
        color: #721c24 !important;
        border: 1px solid #f5c6cb !important;
    }

    .badge-pay-Refunded {
        background-color: #e2e3e5 !important;
        color: #383d41 !important;
        border: 1px solid #d6d8db !important;
    }

    .badge-pay-fallback {
        background-color: #eedff2 !important;
        color: #6f42c1 !important;
        border: 1px solid #e1bee7 !important;
    }

    .btn-details-custom {
        background-color: #212529 !important;
        color: #ffffff !important;
        font-size: 0.8rem !important;
        font-weight: 600 !important;
        padding: 0.4rem 1rem !important;
        transition: background-color 0.2s ease;
    }

        .btn-details-custom:hover {
            background-color: #495057 !important;
        }

    .filter-select {
        border-radius: 8px !important;
        border: 1px solid #ced4da !important;
        font-size: 0.9rem !important;
        padding: 0.45rem 0.75rem !important;
        background-color: #ffffff;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }

    select.filter-select {
        padding-right: 1.8rem !important;
        cursor: pointer;
    }

    .filter-select:focus {
        border-color: #212529 !important;
        box-shadow: 0 0 0 0.2rem rgba(33, 37, 41, 0.15) !important;
        outline: 0;
    }

    .btn-filter-apply {
        background-color: #212529 !important;
        color: #fff !important;
        border-radius: 8px !important;
        font-size: 0.9rem !important;
        padding: 0.45rem 1rem !important;
        font-weight: 500;
    }

        .btn-filter-apply:hover {
            background-color: #495057 !important;
        }

    .btn-filter-reset {
        background-color: #f8f9fa !important;
        color: #495057 !important;
        border: 1px solid #ced4da !important;
        border-radius: 8px !important;
        font-size: 0.9rem !important;
        padding: 0.45rem 1rem !important;
    }

        .btn-filter-reset:hover {
            background-color: #e2e6ea !important;
            color: #212529 !important;
        }

    .admin-toast-success {
        border: 1px solid #212529;
        background-color: #fbfbfb;
        color: #212529;
    }
</style>

<div class="container mt-5" style="max-width: 1200px;">

    <div class="mb-4">
        <h2 class="fw-bold text-dark" style="letter-spacing: -0.5px;">Управління замовленнями</h2>
        <p class="text-muted small mb-0">Панель менеджера для моніторингу, зміни статусів та контролю фінансів StepStyle.</p>
    </div>
    <hr class="text-muted opacity-20 mb-4" />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert admin-toast-success rounded-3 py-3 px-4 mb-4 d-flex align-items-center shadow-sm fw-medium">
            <i class="bi bi-check2-circle fs-5 me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="card p-3 mb-4 table-container shadow-sm border-0">
        <form method="get" class="row g-3 align-items-end">

            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                <label for="searchIdFilter" class="form-label small fw-bold text-secondary text-uppercase mb-2" style="letter-spacing: 0.5px;">
                    <i class="bi bi-hash me-1"></i> № замовлення
                </label>
                <input type="text" id="searchIdFilter" name="searchId" class="form-control filter-select" placeholder="Напр. 5" value="@ViewBag.CurrentSearchId" />
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <label for="paymentStatusFilter" class="form-label small fw-bold text-secondary text-uppercase mb-2" style="letter-spacing: 0.5px;">
                    <i class="bi bi-credit-card me-1"></i> Статус оплати
                </label>
                <select id="paymentStatusFilter" name="paymentStatus" class="form-select filter-select">
                    <option value="">Всі статуси оплати</option>
                    @foreach (var status in paymentStatusesUk)
                    {
                        if (ViewBag.CurrentPaymentStatus == status.Key)
                        {
                            <option value="@status.Key" selected="selected">@status.Value</option>
                        }
                        else
                        {
                            <option value="@status.Key">@status.Value</option>
                        }
                    }
                </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <label for="orderStatusFilter" class="form-label small fw-bold text-secondary text-uppercase mb-2" style="letter-spacing: 0.5px;">
                    <i class="bi bi-truck me-1"></i> Статус замовлення
                </label>
                <select id="orderStatusFilter" name="orderStatus" class="form-select filter-select">
                    <option value="">Всі статуси замовлення</option>
                    @foreach (var status in orderStatusesUk)
                    {
                        if (ViewBag.CurrentOrderStatus == status.Key)
                        {
                            <option value="@status.Key" selected="selected">@status.Value</option>
                        }
                        else
                        {
                            <option value="@status.Key">@status.Value</option>
                        }
                    }
                </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                <label for="orderDateFilter" class="form-label small fw-bold text-secondary text-uppercase mb-2" style="letter-spacing: 0.5px;">
                    <i class="bi bi-calendar3 me-1"></i> Дата
                </label>
                <input type="date" id="orderDateFilter" name="orderDate" class="form-control filter-select" value="@ViewBag.CurrentOrderDate" />
            </div>

            <div class="col-12 col-lg-2 d-flex gap-2 justify-content-end">
                <button type="submit" class="btn btn-filter-apply shadow-sm border-0 d-flex align-items-center w-100 justify-content-center">
                    <i class="bi bi-funnel me-1"></i> Знайти
                </button>
                <a asp-action="Index" class="btn btn-filter-reset d-flex align-items-center justify-content-center">
                    Скинути
                </a>
            </div>
        </form>
    </div>

    <div class="card table-container shadow-sm overflow-hidden mb-5">
        <div class="table-responsive">
            <table class="table table-admin-list table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 70px;">№</th>
                        <th style="width: 160px;">Дата</th>
                        <th>Email клієнта</th>
                        <th style="width: 140px;">Сума</th>
                        <th style="width: 180px;">Статус замовлення</th>
                        <th style="width: 140px;">Оплата</th>
                        <th class="pe-4 text-end" style="width: 110px;">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        var orderStatusStr = order.Status.ToString();
                        var paymentStatusStr = order.PaymentStatus.ToString();

                        var orderStatusUk = orderStatusesUk.ContainsKey(orderStatusStr) ? orderStatusesUk[orderStatusStr] : orderStatusStr;
                        var paymentStatusUk = paymentStatusesUk.ContainsKey(paymentStatusStr) ? paymentStatusesUk[paymentStatusStr] : paymentStatusStr;
                        var hasSpecificStyle = paymentStatusStr == "Pending" || paymentStatusStr == "Unpaid" || paymentStatusStr == "Paid" || paymentStatusStr == "Failed" || paymentStatusStr == "Refunded";
                        var currentBadgeClass = hasSpecificStyle ? $"badge-pay-{paymentStatusStr}" : "badge-pay-fallback";

                        <tr>
                            <td class="ps-4 fw-bold text-dark" style="font-family: monospace;">
                                #@order.Id
                            </td>
                            <td class="text-secondary">
                                @order.OrderDate.ToLocalTime().ToString("dd.MM.yyyy")
                                <span class="text-muted small ms-1">@order.OrderDate.ToLocalTime().ToString("HH:mm")</span>
                            </td>
                            <td class="fw-medium text-dark">
                                @(order.User?.Email ?? "Невідомий користувач")
                            </td>
                            <td class="fw-bold text-dark">
                                @order.TotalAmount.ToString("C")
                            </td>
                            <td>
                                <span class="fw-semibold text-dark" style="font-size: 0.85rem;">
                                    @orderStatusUk
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-order @currentBadgeClass">
                                    @paymentStatusUk
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-details-custom rounded-pill shadow-sm border-0 btn-sm">
                                    Деталі
                                </a>
                            </td>
                        </tr>
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-search fs-2 d-block mb-2 text-muted opacity-50"></i>
                                Замовлень за вказаними критеріями пошуку не знайдено.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>