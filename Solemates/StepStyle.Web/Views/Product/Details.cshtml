@model StepStyle.Web.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var mainImage = Model.Images?.FirstOrDefault(i => i.IsMain)?.ImageUrl
                    ?? Model.Images?.FirstOrDefault()?.ImageUrl
                    ?? "/images/no-image.png";
}

<div class="container my-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Brand" asp-action="Index" class="text-decoration-none text-dark">Каталог</a></li>
            <li class="breadcrumb-item"><a asp-controller="Brand" asp-action="Details" asp-route-id="@Model.BrandId" class="text-decoration-none text-dark">@Model.Brand?.Name</a></li>
            <li class="breadcrumb-item active text-muted">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm overflow-hidden rounded-4">
                <img src="@mainImage" class="img-fluid w-100" style="object-fit: cover; min-height: 500px;" alt="@Model.Name">
            </div>

            @if (Model.Images?.Count > 1)
            {
                <div class="d-flex mt-3 gap-2">
                    @foreach (var img in Model.Images)
                    {
                        <img src="@img.ImageUrl" class="rounded border cursor-pointer" style="width: 80px; height: 80px; object-fit: cover;" />
                    }
                </div>
            }
        </div>

        <div class="col-md-5">
            <div class="ps-md-4">
                <span class="badge bg-light text-dark border mb-2">Артикул: @Model.SKU</span>
                <h1 class="display-5 fw-bold mb-2">@Model.Name</h1>
                <p class="text-muted mb-4">Стать: @Model.Gender</p>

                <h3 class="text-primary fw-bold mb-4">@Model.Price грн.</h3>

                <hr class="my-4 opacity-10">

                <div class="mb-5">
                    <h5 class="fw-bold mb-3 small text-uppercase">Доступні розміри:</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.Variants != null && Model.Variants.Any(v => v.QuantityInStock > 0))
                        {
                            @foreach (var variant in Model.Variants.Where(v => v.QuantityInStock > 0).OrderBy(v => v.Size.Value))
                            {
                                <div class="btn btn-outline-dark px-3 py-2 fw-semibold rounded-3">
                                    @variant.Size?.Value
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-danger fw-bold">Немає в наявності</span>
                        }
                    </div>
                </div>

                <div class="mb-4">
                    <h5 class="fw-bold mb-2 small text-uppercase">Про товар:</h5>
                    <p class="text-secondary lh-lg" style="white-space: pre-line;">
                        @Model.Description
                    </p>
                </div>

                <div class="d-grid gap-2 pt-3">
                    <button class="btn btn-dark btn-lg py-3 rounded-pill fw-bold" disabled title="Це режим перегляду">
                        <i class="bi bi-cart-plus me-2"></i> Додати в кошик
                    </button>
                    <a asp-controller="Brand" asp-action="Details" asp-route-id="@Model.BrandId" class="btn btn-link text-decoration-none text-muted">
                        Повернутися до списку бренду
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
        transition: 0.3s;
    }

        .cursor-pointer:hover {
            border-color: #000 !important;
            transform: scale(1.05);
        }
</style>