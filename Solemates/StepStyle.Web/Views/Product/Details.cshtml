@model StepStyle.Web.Models.Product
@using StepStyle.Web.Models.DTOs

@{
    ViewData["Title"] = Model.Name;
    var mainImage = Model.Images?.FirstOrDefault(i => i.IsMain)?.ImageUrl
                    ?? Model.Images?.FirstOrDefault()?.ImageUrl
                    ?? "/images/no-image.png";

    var countryInfo = ViewBag.CountryInfo as CountryDto;
    var pexelsData = ViewBag.PexelsPhotos as PexelsDto;
}

<div class="container my-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-dark alert-dismissible fade show shadow-sm rounded-4 border-0 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-4 me-3 text-success"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (User.IsInRole("Admin"))
    {
        <div class="alert alert-dark border-0 shadow-sm d-flex justify-content-between align-items-center rounded-4 mb-4">
            <div>
                <strong>Панель адміністратора:</strong> Модерація товару увімкнена.
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm px-4 rounded-pill fw-bold shadow-sm border-0 text-dark">
                    Редагувати
                </a>

                <form asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Видалити цей товар назавжди?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm px-4 rounded-pill fw-bold shadow-sm border-0">
                        Видалити
                    </button>
                </form>
            </div>
        </div>
    }

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Brand" asp-action="Index" class="text-decoration-none text-dark opacity-50">Каталог</a></li>
            <li class="breadcrumb-item"><a asp-controller="Brand" asp-action="Details" asp-route-id="@Model.BrandId" class="text-decoration-none text-dark opacity-50">@Model.Brand?.Name</a></li>
            <li class="breadcrumb-item active text-dark fw-bold">@Model.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm overflow-hidden rounded-4 mb-3 bg-white">
                <img id="mainViewImage" src="@mainImage" class="img-fluid w-100"
                     style="object-fit: contain; min-height: 350px; max-height: 500px; transition: 0.3s;"
                     alt="@Model.Name" onerror="this.src='/images/no-image.png'">
            </div>

            @if (Model.Images != null && Model.Images.Any())
            {
                <div class="d-flex mt-3 gap-2 overflow-auto pb-2 custom-scrollbar">
                    @foreach (var img in Model.Images.OrderByDescending(i => i.IsMain))
                    {
                        <div class="thumb-wrapper">
                            <img src="@img.ImageUrl"
                                 class="rounded border cursor-pointer thumb-img @(img.ImageUrl == mainImage ? "active-thumb" : "")"
                                 style="width: 70px; height: 70px; object-fit: contain;"
                                 onclick="changeMainImage(this)"
                                 alt="@Model.Name" />
                        </div>
                    }
                </div>
            }
        </div>

        <div class="col-md-5">
            <div class="ps-md-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-dark px-3 py-2 rounded-pill text-uppercase">@Model.Brand?.Name</span>

                        @if (countryInfo != null)
                        {
                            <div class="d-flex align-items-center bg-white border rounded-pill px-2 py-1 shadow-sm">
                                <img src="@countryInfo.Flags?.Png" style="width: 18px; height: auto;" class="rounded-1 me-1" />
                                <span class="small fw-bold text-dark" style="font-size: 0.7rem;">@countryInfo.Name?.Common</span>
                            </div>
                        }
                    </div>
                    <span class="badge bg-light text-dark border rounded-pill small">АРТ: @Model.SKU</span>
                </div>

                <h1 class="display-5 fw-bold mb-2">@Model.Name</h1>

                <div class="mb-3">
                    <h3 class="text-dark fw-bold mb-0">@(((decimal)Model.Price).ToString("N0")) ₴</h3>

                    @if (ViewBag.UsdPrice != null || ViewBag.EurPrice != null)
                    {
                        <div class="text-muted small mt-1 fw-medium">
                            @if (ViewBag.UsdPrice != null)
                            {
                                <span class="me-3"><i class="bi bi-currency-dollar"></i> @ViewBag.UsdPrice USD</span>
                            }
                            @if (ViewBag.EurPrice != null)
                            {
                                <span><i class="bi bi-currency-euro"></i> @ViewBag.EurPrice EUR</span>
                            }
                        </div>
                    }
                </div>

                <hr class="my-4 opacity-10">

                <div class="mb-4">
                    <h6 class="fw-bold text-uppercase small letter-spacing-1 mb-3">Оберіть розмір:</h6>
                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.Variants != null && Model.Variants.Any(v => v.QuantityInStock > 0))
                        {
                            @foreach (var variant in Model.Variants.Where(v => v.QuantityInStock > 0).OrderBy(v => v.Size.Value))
                            {
                                <button type="button" class="btn btn-light px-3 py-2 fw-bold rounded-3 size-selector shadow-sm" data-variant-id="@variant.Id">
                                    @variant.Size?.Value
                                </button>
                            }
                        }
                        else
                        {
                            <div class="alert alert-secondary w-100 py-2 small border-0 rounded-4">
                                <i class="bi bi-info-circle me-2"></i>Тимчасово розпродано
                            </div>
                        }
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold text-uppercase small letter-spacing-1 mb-2">Опис моделі:</h6>
                    <p class="text-secondary lh-lg" style="white-space: pre-line; font-size: 0.95rem;">@Model.Description</p>
                </div>

                <div class="pt-2">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" id="addToCartForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productVariantId" id="selectedVariantId" value="" required />
                        <input type="hidden" name="quantity" value="1" />

                        <div class="d-grid gap-2">
                            <button type="submit" id="btnAddToCartSubmit" class="btn btn-dark btn-lg py-3 rounded-4 fw-bold shadow-sm btn-cart-main text-uppercase" disabled>
                                Оберіть розмір
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @if (pexelsData?.Photos != null && pexelsData.Photos.Any())
    {
        <div class="row mt-5 pt-5">
            <div class="col-12 text-center mb-4">
                <h4 class="fw-bold text-uppercase letter-spacing-1">Естетика @Model.Brand?.Name</h4>
                <p class="text-muted small">Натхнення вашим стилем • Powered by Pexels</p>
            </div>
            <div class="col-12">
                <div class="row g-3">
                    @foreach (var photo in pexelsData.Photos.Take(3))
                    {
                        <div class="col-md-4">
                            <div class="position-relative overflow-hidden rounded-4 shadow-sm photo-hover-card" style="height: 300px;">
                                <img src="@photo.Src?.Large" class="w-100 h-100" style="object-fit: cover;" alt="@photo.Alt">
                                <div class="position-absolute bottom-0 start-0 p-3 text-white w-100" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                                    <small style="font-size: 0.65rem;">Ph: @photo.Photographer</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="row mt-5 pt-4 border-top">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0 text-uppercase">Відгуки клієнтів</h3>
                <span class="badge bg-dark text-white rounded-pill px-3 py-2 shadow-sm">Всього: @(Model.Reviews?.Count ?? 0)</span>
            </div>

            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                <div class="d-flex flex-column gap-4">
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.DatePosted))
                    {
                        var parts = review.Text.Split("|ADMIN_REPLY|");
                        var userText = parts[0];
                        var adminReply = parts.Length > 1 ? parts[1] : null;

                        <div class="card border-0 shadow-sm rounded-4 p-4 bg-light position-relative">
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="position-absolute top-0 end-0 m-3">
                                    <form asp-controller="Review" asp-action="DeleteReview" asp-route-id="@review.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link text-danger p-0" onclick="return confirm('Видалити цей відгук?');">
                                            <i class="bi bi-x-circle-fill fs-5"></i>
                                        </button>
                                    </form>
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="d-flex align-items-center">
                                    <div class="bg-dark text-white rounded-circle d-flex justify-content-center align-items-center me-3 shadow-sm fw-bold" style="width: 45px; height: 45px;">
                                        @(review.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@(review.User?.UserName ?? "Користувач")</div>
                                        <div class="text-warning small">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                <i class="bi bi-star@(i < review.Rating ? "-fill" : "")"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="text-muted small fw-bold">@review.DatePosted.ToString("dd.MM.yyyy")</div>
                            </div>

                            <p class="mt-2 mb-2 text-dark lh-base">@userText</p>

                            @if (!string.IsNullOrEmpty(adminReply))
                            {
                                <div class="mt-3 ms-md-4 p-3 bg-white rounded-4 border-start border-dark border-4 shadow-sm">
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bi bi-patch-check-fill text-dark me-2"></i>
                                        <span class="fw-bold small text-uppercase">Відповідь StepStyle</span>
                                    </div>
                                    <p class="small mb-0 text-secondary">@adminReply</p>
                                </div>
                            }
                            else if (User.IsInRole("Admin"))
                            {
                                <div class="mt-3">
                                    <button class="btn btn-dark btn-sm rounded-pill px-3 fw-bold shadow-sm"
                                            type="button" data-bs-toggle="collapse" data-bs-target="#replyForm-@review.Id">
                                        <i class="bi bi-reply-fill me-1"></i> ВІДПОВІСТИ
                                    </button>
                                    <div class="collapse" id="replyForm-@review.Id">
                                        <form asp-controller="Review" asp-action="ReplyToReview" method="post" class="mt-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ReviewId" value="@review.Id" />
                                            <div class="input-group">
                                                <textarea name="ReplyText" class="form-control rounded-4 shadow-sm" placeholder="Ваша відповідь..." required></textarea>
                                                <button type="submit" class="btn btn-dark rounded-4 ms-2 px-4 fw-bold">
                                                    <i class="bi bi-send"></i>
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 bg-light rounded-4 border border-dashed">
                    <i class="bi bi-chat-left-dots text-muted opacity-25 mb-2" style="font-size: 2.5rem;"></i>
                    <h6 class="text-muted fw-bold text-uppercase">Відгуків поки немає</h6>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(element) {
            const mainImg = document.getElementById('mainViewImage');
            mainImg.style.opacity = '0.5';

            setTimeout(() => {
                mainImg.src = element.src;
                mainImg.style.opacity = '1';

                document.querySelectorAll('.thumb-img').forEach(img => {
                    img.classList.remove('active-thumb');
                });
                element.classList.add('active-thumb');
            }, 150);
        }

        document.addEventListener("DOMContentLoaded", function () {
            const sizeButtons = document.querySelectorAll(".size-selector");
            const hiddenInput = document.getElementById("selectedVariantId");
            const btnAddToCart = document.getElementById("btnAddToCartSubmit");

            sizeButtons.forEach(button => {
                button.addEventListener("click", function () {
                    sizeButtons.forEach(btn => btn.classList.remove("active"));
                    this.classList.add("active");

                    const variantId = this.getAttribute("data-variant-id");
                    hiddenInput.value = variantId;

                    btnAddToCart.removeAttribute("disabled");
                    btnAddToCart.innerText = "Додати в кошик";
                });
            });
        });
    </script>
}

<style>
    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .size-selector {
        background-color: #f1f3f5;
        border: none;
        color: #212529;
        min-width: 60px;
        transition: all 0.2s ease;
    }

        .size-selector:hover {
            background-color: #e9ecef;
            transform: translateY(-2px);
        }

        .size-selector:focus, .size-selector.active {
            background-color: #212529 !important;
            color: white !important;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

    .btn-cart-main {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
    }

        .btn-cart-main:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2) !important;
            background-color: #000;
        }

    .cursor-pointer {
        cursor: pointer;
        transition: 0.3s;
    }

        .cursor-pointer:hover {
            transform: translateY(-3px);
        }

    .thumb-img {
        border: 2px solid transparent;
        transition: all 0.2s ease-in-out;
        opacity: 0.7;
    }

        .thumb-img:hover, .thumb-img.active-thumb {
            border-color: #212529;
            opacity: 1;
            transform: scale(1.05);
        }

    .active-thumb {
        border-color: #212529 !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .custom-scrollbar::-webkit-scrollbar {
        height: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #dee2e6;
        border-radius: 10px;
    }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
    }

    .photo-hover-card img {
        transition: 0.5s;
    }

    .photo-hover-card:hover img {
        transform: scale(1.1);
    }
</style>