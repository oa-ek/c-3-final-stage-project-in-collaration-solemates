@model StepStyle.Web.Models.Product

@{
    ViewData["Title"] = "Редагувати товар";
}

<div class="container my-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">
            <h2 class="h5 m-0">Редагування товару: @Model.Name</h2>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="BrandId" />
                <input type="hidden" asp-for="CategoryId" />

                <div class="row">
                    <div class="col-md-6 border-end">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold small text-uppercase">Назва моделі</label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SKU" class="form-label fw-bold small text-uppercase">Артикул (SKU)</label>
                            <input asp-for="SKU" class="form-control" />
                            <span asp-validation-for="SKU" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold small text-uppercase">Ціна (грн)</label>
                                <div class="input-group">
                                    <input asp-for="Price" type="number" step="0.01" class="form-control" />
                                    <span class="input-group-text bg-light">₴</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Gender" class="form-label fw-bold small text-uppercase">Стать</label>
                                <select asp-for="Gender" class="form-select"
                                        asp-items="Html.GetEnumSelectList<StepStyle.Web.Models.Gender>()">
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold small text-uppercase">Опис товару</label>
                            <textarea asp-for="Description" class="form-control" rows="8"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4 opacity-25" />

                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">ID: #@Model.Id</small>
                    <div>
                        <a asp-controller="Brand" asp-action="Details" asp-route-id="@Model.BrandId" class="btn btn-outline-secondary me-2">Скасувати</a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold">Зберегти зміни</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}