@model StepStyle.Web.Models.Product

@{
    ViewData["Title"] = "Редагувати товар";
    var allSizes = ViewBag.FullSizesList as List<StepStyle.Web.Models.Size>;
    var firstImage = Model.Images?.FirstOrDefault(i => i.IsMain) ?? Model.Images?.FirstOrDefault();
}

<div class="container my-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h2 class="h5 m-0">Редагування: @Model.Name</h2>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="BrandId" />
                <input type="hidden" asp-for="CategoryId" />

                <div class="row">
                    <div class="col-md-6 border-end">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold small text-uppercase">Назва моделі</label>
                            <input asp-for="Name" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="SKU" class="form-label fw-bold small text-uppercase">Артикул (SKU)</label>
                            <input asp-for="SKU" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold small text-uppercase">Ціна (грн)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gender" class="form-label fw-bold small text-uppercase">Стать</label>
                                <select asp-for="Gender" class="form-select" asp-items="Html.GetEnumSelectList<StepStyle.Web.Models.Gender>()"></select>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-uppercase">Фото товару</label>
                            <div class="d-flex align-items-center bg-light p-2 rounded mb-2">
                                @if (firstImage != null)
                                {
                                    <img src="@firstImage.ImageUrl" style="width: 60px; height: 60px; object-fit: cover;" class="rounded me-3 border" />
                                    <input type="hidden" name="ExistingImageId" value="@firstImage.Id" />
                                    <input type="hidden" name="ExistingImageUrl" value="@firstImage.ImageUrl" />
                                }
                                <input type="file" name="uploadedImage" class="form-control form-control-sm" accept="image/*" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold small text-uppercase">Опис</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <h5 class="fw-bold text-secondary mb-3 small text-uppercase">Наявність по розмірах</h5>
                <div class="row bg-light p-3 rounded border">
                    @if (allSizes != null)
                    {
                        for (int i = 0; i < allSizes.Count; i++)
                        {
                            var currentVariant = Model.Variants?.FirstOrDefault(v => v.SizeId == allSizes[i].Id);
                            var quantity = currentVariant?.QuantityInStock ?? 0;

                            <div class="col-lg-2 col-md-3 col-4 mb-3">
                                <div class="card text-center border-primary shadow-sm">
                                    <div class="card-header py-1 bg-primary text-white fw-bold small">
                                        @allSizes[i].Value
                                    </div>
                                    <div class="card-body p-2">
                                        <input type="hidden" name="Variants[@i].SizeId" value="@allSizes[i].Id" />
                                        <input type="number" name="Variants[@i].QuantityInStock"
                                               class="form-control form-control-sm text-center"
                                               value="@quantity" min="0" />
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <small class="text-muted">ID: #@Model.Id</small>
                    <div>
                        <a asp-controller="Brand" asp-action="Details" asp-route-id="@Model.BrandId" class="btn btn-outline-secondary me-2">Скасувати</a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold shadow">Зберегти зміни</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>